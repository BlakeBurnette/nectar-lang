// std-lib.nectar — Nectar standard library usage
//
// The standard library is implicit — no imports needed.
// If you use a function, the compiler auto-includes the module.
// If you don't use it, it doesn't exist in your output.

// --- Debounce & Throttle ---
// Built-in event handler operators. No lodash.

component SearchBox() {
    let mut query: String = "";
    let mut results: Vec<String> = vec![];

    // debounce: waits 300ms after last keystroke before executing
    fn on_input(&mut self, value: String) {
        self.query = value;
        let search = debounce(self.do_search, 300);
        search();
    }

    // throttle: executes at most once per 100ms
    fn on_scroll(&self) {
        let handler = throttle(self.load_more, 100);
        handler();
    }

    fn do_search(&mut self) {
        self.results = fetch(f"/api/search?q={self.query}");
    }

    fn load_more(&self) {
        // Load next page
    }

    render {
        <div>
            <input type="text" bind:value={query} on:input={self.on_input} />
            {for result in self.results {
                <p>{result}</p>
            }}
        </div>
    }
}

// --- BigDecimal ---
// Arbitrary precision arithmetic. No floating-point surprises.

fn calculate_invoice() {
    let subtotal = BigDecimal::new("19.99");
    let tax_rate = BigDecimal::new("0.0825");
    let tax = subtotal.mul(tax_rate);          // 1.649175 — exact
    let total = subtotal.add(tax);             // 21.639175 — exact

    // Compare: in JavaScript, 19.99 * 0.0825 = 1.6491750000000001
    // BigDecimal never loses precision.
}

// --- Format ---
// Locale-aware number, currency, and time formatting.

component PriceDisplay(amount: f64) {
    render {
        <div>
            <p>{format::currency(self.amount, "USD", "en-US")}</p>
            <p>{format::compact(1234567.0)}</p>
            <p>{format::percent(0.156)}</p>
            <p>{format::bytes(1048576)}</p>
            <p>{format::ordinal(42)}</p>
        </div>
    }
}
// Output: "$1,234.50", "1.2M", "15.6%", "1.0 MB", "42nd"

// --- Collections ---
// groupBy, sortBy, uniqBy, chunk, flatten, zip, partition.

fn process_users(users: Vec<User>) {
