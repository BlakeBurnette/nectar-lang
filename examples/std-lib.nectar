// --- URL Builder ---
// Parse, build, and manipulate URLs. No query-string package.

fn build_api_url() {
    let parsed = url::parse("https://api.example.com/users?page=1");
    let with_filter = url::query_set(parsed.href, "role", "admin");
    let page = url::query_get(parsed.href, "page");  // Some("1")
}

// --- Input Masking ---
// Format user input as they type.

component PhoneInput() {
    let mut raw: String = "";

    fn on_input(&mut self, value: String) {
        self.raw = mask::phone(value);  // "(555) 123-4567"
    }

    render {
        <input type="text" value={self.raw} on:input={self.on_input}
               placeholder="(555) 555-5555" />
    }
}

component CardInput() {
    let mut card: String = "";

    fn on_input(&mut self, value: String) {
        self.card = mask::credit_card(value);  // "4242 4242 4242 4242"
    }

    render {
        <input type="text" value={self.card} on:input={self.on_input} />
    }
}

// --- Fuzzy Search ---
// Client-side search. No Fuse.js.

component UserSearch(users: Vec<User>) {
    let mut query: String = "";
    let mut results: Vec<User> = vec![];
    let index: SearchIndex = search::create_index(self.users, vec!["name", "email"]);

    fn on_search(&mut self, q: String) {
        self.query = q;
        self.results = search::query(self.index, q);
    }

    render {
        <div>
            <input type="text" bind:value={query} on:input={self.on_search} />
            {for user in self.results {
                <p>{user.name}</p>
            }}
        </div>
    }
}

// --- Toast Notifications ---
// No react-toastify. No sonner.

component SaveButton() {
    fn save(&self) {
        let result = fetch("/api/save");
        match result {
            Ok(_) => toast.success("Saved successfully"),
            Err(e) => toast.error(f"Save failed: {e}"),
        }
    }

    render {
        <button on:click={self.save}>"Save"</button>
    }
}

// --- Skeleton Loading ---
// Shimmer placeholders while data loads.

component UserProfile() {
    let mut loading: bool = true;
    let mut user: Option<User> = None;

    render {
        {if self.loading {
            <div>
                {skeleton.circle(64)}
                {skeleton.text(3)}
            </div>
        } else {
            <div>
                <img src={self.user.avatar} />
                <p>{self.user.name}</p>
            </div>
        }}
    }
}

// --- Pagination ---
// Built-in. No library.

component UserList(users: Vec<User>) {
    let mut current_page: i32 = 1;
    let per_page: i32 = 25;

    render {
        <div>
            {let page = pagination.paginate(self.users, self.current_page, self.per_page);
             for user in page.data {
                <p>{user.name}</p>
             }}

            {let pages = pagination.page_numbers(self.current_page, page.total_pages);
             for p in pages {
                <button on:click={self.current_page = p}>{f"{p}"}</button>
             }}
        </div>
    }
}

// --- Everything is auto-included ---
//
// The compiler sees: debounce → includes std_util (0.4KB)
// The compiler sees: BigDecimal → includes std_decimal (1.2KB)
// The compiler sees: format::currency → includes std_format (0.8KB)
// The compiler sees: toast.success → includes std_toast (0.6KB)
//
// If you don't use it, it's not in your bundle. Zero config.
